# ─────────────────────────────────────────────────────────────────────────────
#  Payment Sandbox — environment configuration
#  Copy this file to `.env` and fill in your SANDBOX credentials.
#  NEVER put production/live keys here. This app is sandbox-only by design.
# ─────────────────────────────────────────────────────────────────────────────

# ── Evervault (3-D Secure) ───────────────────────────────────────────────────
# Dashboard: https://app.evervault.com
# API key must have the "Create 3DS Session" + "Retrieve 3DS Session" permissions.
EVERVAULT_API_KEY=ev:key:xxxxxxxxxxxxxxxxxxxxxxxx
# App Settings → General → App ID
EVERVAULT_APP_ID=app_xxxxxxxxxxxx
# Team Settings → General → Team ID  (safe to expose to the browser)
EVERVAULT_TEAM_ID=team_xxxxxxxxxxxx

# ── Checkout.com (card authorization, SANDBOX) ───────────────────────────────
# Sandbox secret key: sandbox.checkout.com → Settings → Channels → Secret Key
CHECKOUT_SECRET_KEY=sk_sbox_xxxxxxxxxxxxxxxxxxxxxxxx
# Your UNIQUE prefixed base URL. Find it at: Dashboard → Developers → Overview.
# Format: https://XXXXXXXX.api.sandbox.checkout.com   (the generic URL will NOT work)
CHECKOUT_BASE_URL=https://xxxxxxxx.api.sandbox.checkout.com
# Optional: ties requests to a specific processing channel (pc_xxx). Leave blank if unused.
CHECKOUT_PROCESSING_CHANNEL_ID=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Persistence (optional) ───────────────────────────────────────────────────
# Leave blank to use the built-in in-memory store (zero config, resets on restart).
# Set a Postgres connection string to persist transaction history across restarts.
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# ── Security / operations (optional) ─────────────────────────────────────────
# Comma-separated list of extra origins allowed to call the API (CORS).
# Same-origin is always allowed; leave blank if the app serves its own frontend.
ALLOWED_ORIGINS=
# When "true", API errors include upstream detail (handy locally, avoid in prod).
DEBUG_ERRORS=false
# Trust the X-Forwarded-* headers from a hosting proxy/load balancer.
TRUST_PROXY=true
# Requests per minute per IP for the payment/session endpoints.
PAYMENT_RATE_LIMIT=30
# Timeout (ms) for calls to Evervault / Checkout.com before giving up.
UPSTREAM_TIMEOUT_MS=20000
