{
  "name": "payment-sandbox",
  "version": "1.0.0",
  "private": true,
  "description": "A hosted 3-D Secure + card payment simulator built on the Evervault and Checkout.com sandboxes. No real payments, no logins, no cardholder data stored.",
  "type": "commonjs",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "pg": "^8.12.0"
  }
}
